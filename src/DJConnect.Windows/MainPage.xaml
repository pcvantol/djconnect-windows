                                    <Label Text="Microfoon&#10;Nodig voor push-to-talk muziekverzoeken." TextColor="{StaticResource TextPrimary}" />
                                    <Button Grid.Column="1" Text="Microfoon toestaan" Clicked="OpenMicrophoneSettingsFromSettings" />
                                    <Label Grid.Row="1" Text="Notificaties&#10;Voor Windows toast-meldingen wanneer ondersteund." TextColor="{StaticResource TextPrimary}" />
                                    <Button Grid.Row="1" Grid.Column="1" Text="Notificaties toestaan" Command="{Binding EnableNotificationsCommand}" />
                                    <Label Grid.Row="2" Text="Lokaal netwerk / firewall&#10;Nodig voor pairing met Home Assistant op hetzelfde LAN." TextColor="{StaticResource TextPrimary}" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding LocalNetworkPermissionStatus}" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="12">
                                <Label Text="DIAGNOSTIEK" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Label Text="Logniveau" TextColor="{StaticResource TextSecondary}" />
                                    <Picker Grid.Column="1" SelectedItem="{Binding LogLevel}" TextColor="{StaticResource TextPrimary}" BackgroundColor="#2B3262">
                                        <Picker.Items>
                                            <x:String>error</x:String>
                                            <x:String>warning</x:String>
                                            <x:String>info</x:String>
                                            <x:String>debug</x:String>
                                        </Picker.Items>
                                    </Picker>
                                    <Label Grid.Row="1" Text="Logs" TextColor="{StaticResource TextSecondary}" />
                                    <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button Text="⧉  Logs kopiëren" Command="{Binding CopyLogsCommand}" />
                                        <Button Grid.Column="1" Text="Logs wissen" Command="{Binding ClearLogsCommand}" />
                                    </Grid>
                                </Grid>
                                <Label Text="Logs worden vóór kopiëren geredigeerd. Secrets worden nooit automatisch geüpload." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="APP-INFO" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
