                                            TextColor="{StaticResource TextPrimary}"
                                            BackgroundColor="#2B3262" />
                                </Grid>
                                <Label Text="Playback-start is geblokkeerd zolang geen uitvoerapparaat is geselecteerd." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="22">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="ASK DJ" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                    <Label Text="Lokale audio replay" TextColor="{StaticResource TextSecondary}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding LocalAudioReplayEnabled}" HorizontalOptions="Start" />
