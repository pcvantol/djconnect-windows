                            <Button x:Name="PaddleGameButton" Text="▭  Paddle Rally&#10;High 0" Clicked="SelectPaddleGame" />
                            <Button x:Name="MeteorGameButton" Grid.Column="1" Text="☄  Meteor Run&#10;High 0" Clicked="SelectMeteorGame" />
                            <Button x:Name="SkyGameButton" Grid.Column="2" Text="✦  Sky Dash&#10;High 0" Clicked="SelectSkyGame" />
                            <Button x:Name="MazeGameButton" Grid.Column="3" Text="▦  Maze Chase&#10;High 0" Clicked="SelectMazeGame" />
                        </Grid>

                        <Border Padding="18" Background="{StaticResource CardBrush}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label x:Name="GameTitleLabel" Text="Paddle Rally" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Accent}" />
                                        <Label x:Name="GameHintLabel" Text="Gebruik ↑/↓ of sleep de paddle. Houd de bal in het spel." TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Label x:Name="GameScoreLabel" Grid.Column="1" Text="Score 0   High 0" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>

                                <Border Grid.Row="1" Stroke="{StaticResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="#05050A">
                                    <Grid>
                                        <GraphicsView x:Name="MiniGameSurface"
                                                      HeightRequest="520"
                                                      MinimumHeightRequest="360"
                                                      HorizontalOptions="Fill"
                                                      VerticalOptions="Fill"
                                                      StartInteraction="MiniGameSurfaceStartInteraction"
                                                      DragInteraction="MiniGameSurfaceDragInteraction"
                                                      EndInteraction="MiniGameSurfaceEndInteraction" />
                                        <Button x:Name="GameIdleButton"
                                                Text="▶  Tik of klik om te spelen"
                                                WidthRequest="260"
                                                HeightRequest="58"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                Clicked="StartMiniGameClicked" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                        <Button Text="▶  Start" Clicked="StartMiniGameClicked" />
                                        <Button Grid.Column="1" Text="Ⅱ  Pauze" Clicked="PauseMiniGameClicked" />
                                        <Button Grid.Column="2" Text="↻  Opnieuw" Clicked="RestartMiniGameClicked" />
                                        <Button Grid.Column="3" Text="Highscores wissen" Clicked="ClearGameHighscoresClicked" />
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10">
                                        <Button Text="←" Clicked="MiniGameLeftClicked" />
                                        <Button Grid.Column="1" Text="↑" Clicked="MiniGameUpClicked" />
                                        <Button Grid.Column="2" Text="↓" Clicked="MiniGameDownClicked" />
                                        <Button Grid.Column="3" Text="→" Clicked="MiniGameRightClicked" />
                                        <Button Grid.Column="4" Text="Actie" Clicked="MiniGameActionClicked" />
                                    </Grid>
                                </Grid>

                                <Label Grid.Row="3" Text="Gebruik de knoppen, tik of sleep binnen het speelveld. Alles blijft lokaal en gebruikt Home Assistant niet." TextColor="{StaticResource TextSecondary}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <ScrollView x:Name="SettingsPanel" IsVisible="False">
                    <VerticalStackLayout Spacing="22" MaximumWidthRequest="1040">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding SettingsTitle}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Configuratie, pairing, permissions en diagnostiek. DJConnect uploadt niets automatisch." TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border IsVisible="{Binding HasPermissionNotice}" Padding="14" BackgroundColor="#2A2352" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                            <Label Text="{Binding PermissionNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="22">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="VERBINDING" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                    <Label Text="Pairing status" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="1" Text="{Binding SettingsPairingStatusText}" TextColor="{StaticResource TextPrimary}" />
                                    <Label Grid.Row="1" Text="Home Assistant URL" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Grid.Row="1" Grid.Column="1" Text="{Binding HomeAssistantUrl}" BackgroundColor="#071026" TextColor="{StaticResource TextPrimary}" Placeholder="https://homeassistant.local:8123" />
                                    <Label Grid.Row="2" Text="Client adres" TextColor="{StaticResource TextSecondary}" />
                                    <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Text="{Binding ClientAddressDisplay}" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        <Button Grid.Column="1" Text="⧉" WidthRequest="52" Clicked="CopyClientAddressClicked" IsEnabled="{Binding CanCopyClientAddress}" />
                                    </Grid>
                                    <Label Grid.Row="3" Text="Runtime" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding SettingsRuntimeSummary}" TextColor="{StaticResource TextPrimary}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Text="Opslaan" Command="{Binding SaveSettingsCommand}" />
                                    <Button Grid.Column="1" Text="↻  App opnieuw koppelen" Clicked="ResetPairingFromSettingsClicked" />
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="12">
