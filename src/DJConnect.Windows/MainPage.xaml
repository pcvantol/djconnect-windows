                                    <Label Grid.Row="2" Text="Status" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding WakewordStatusText}" TextColor="{StaticResource TextPrimary}" />
                                </Grid>
                                <Label Text="Push-to-talk en tekstchat blijven beschikbaar zonder wakeword. Stemactivatie start geen achtergrondluisteren in deze build." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="12">
                                <Label Text="DEMO MODE" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="Volledig lokaal voor UI-inspectie. Demo mode belt Home Assistant niet en slaat geen bearer token op." TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" />
                                <Button Text="▶  Demo Mode starten" Clicked="StartDemoModeClicked" IsVisible="{Binding IsNotDemoMode}" />
                                <Button Text="Demo Mode stoppen" Command="{Binding StopDemoModeCommand}" IsVisible="{Binding IsDemoMode}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="22">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="PERMISSIONS" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
