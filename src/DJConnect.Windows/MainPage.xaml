                                            <Label Grid.Column="2" Text="{Binding Level}" FontFamily="Courier New" FontSize="13" FontAttributes="Bold" TextColor="{Binding LevelColor}" VerticalOptions="Center" />
                                            <Label Grid.Column="3" Text="{Binding DisplayText}" FontFamily="Courier New" FontSize="13" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Grid>

