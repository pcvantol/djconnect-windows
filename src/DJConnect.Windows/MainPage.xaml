                                <Label Text="Geen logs" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Diagnostische gebeurtenissen verschijnen hier." TextColor="{StaticResource TextSecondary}" />
