                    <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoadingWhatsNew}" IsVisible="{Binding IsLoadingWhatsNew}" Color="{StaticResource Accent}" />

                    <ScrollView Grid.Row="2" HeightRequest="360">
                        <Label Text="{Binding WhatsNewBody}" TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" FontSize="16" />
                    </ScrollView>

                    <Label Grid.Row="3" Text="https://djconnect.dev" TextColor="{StaticResource TextSecondary}" />

                    <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="{Binding T[Xaml_Doorgaan]}" HeightRequest="56" Command="{Binding DismissWhatsNewCommand}" />
                        <Button Grid.Column="1" Text="{Binding T[Xaml_Bekijk_online]}" HeightRequest="56" Clicked="OpenWhatsNewOnline" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsPermissionExplanationVisible}" BackgroundColor="#CC050717">
            <Border Padding="28" WidthRequest="620" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="18">
                        <Border BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" WidthRequest="64" HeightRequest="64">
                            <Label Text="{Binding PermissionIcon}" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{StaticResource Accent}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding PermissionTitle}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding PermissionIntro}" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border Padding="18" BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding PermissionBodyPrimary}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                            <Label Text="{Binding PermissionBodySecondary}" TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" />
                            <Label IsVisible="{Binding HasPermissionBodyTertiary}" Text="{Binding PermissionBodyTertiary}" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="{Binding PermissionContinueText}" HeightRequest="56" Clicked="ContinuePermissionExplanationClicked" />
                        <Button Grid.Column="1" Text="{Binding T[Xaml_Niet_nu_4]}" HeightRequest="56" Command="{Binding HidePermissionExplanationCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding IsLocalNetworkPermission}">
                        <Button Text="{Binding T[Xaml_Lokale_pairing_doorgaan]}" HeightRequest="52" Command="{Binding SaveSettingsCommand}" />
                        <Button Grid.Column="1" Text="{Binding T[Xaml_Open_firewall_instellingen]}" HeightRequest="52" Clicked="OpenPermissionSettingsClicked" />
                    </Grid>

                    <Button IsVisible="{Binding IsPermissionSettingsMode}" Text="{Binding PermissionSettingsText}" HeightRequest="52" Clicked="OpenPermissionSettingsClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
