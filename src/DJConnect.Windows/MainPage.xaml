                        <VerticalStackLayout Spacing="6">
                            <Label Text="Hulp" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="Open Home Assistant > Integraties > DJConnect. Als discovery niet werkt, vul het Client adres handmatig in. Zorg dat Windows en Home Assistant op hetzelfde lokale netwerk zitten; firewall kan lokale pairing blokkeren." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Button Text="App afsluiten" HeightRequest="58" Clicked="ExitAppClicked" />
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsPairingSuccessVisible}" Spacing="18">
                        <Border Padding="18" BackgroundColor="#143A2A" Stroke="#35E56B" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Succesvol gekoppeld" FontSize="26" FontAttributes="Bold" TextColor="#35E56B" HorizontalTextAlignment="Center" />
                                <Label Text="Het DJConnect device-token is app-private opgeslagen. mDNS discovery is gestopt." TextColor="{StaticResource TextPrimary}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Button Text="Aan de slag!" HeightRequest="58" Command="{Binding CompletePairingSuccessCommand}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsCrashReportPromptVisible}" BackgroundColor="#AA000000">
            <Border Padding="24" WidthRequest="780" MaximumWidthRequest="780" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
                    <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="16">
                        <Border BackgroundColor="#4A3219" Stroke="#F59E0B" StrokeShape="RoundRectangle 8" WidthRequest="56" HeightRequest="56">
                            <Label Text="⚠" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="#FBBF24" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="De app is mogelijk gecrasht" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Je kunt privacy-safe diagnostiek kopiëren of een GitHub issue voorbereiden." TextColor="{StaticResource TextSecondary}" />
                            <Label Text="Er wordt niets automatisch geüpload." TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="✕" Command="{Binding DismissCrashReportCommand}" WidthRequest="52" />
                    </Grid>

                    <Border Grid.Row="1" IsVisible="{Binding HasCrashReportNotice}" Padding="12" BackgroundColor="#143A2A" Stroke="#35E56B" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding CrashReportNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                    </Border>

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <Label Text="App versie" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding AppVersion}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="1" Text="Protocol" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding ProtocolVersion}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Text="Client type" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding ClientType}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="3" Text="OS" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding FeedbackOsVersion}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="4" Text="Pairing" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="4" Grid.Column="1" Text="{Binding FeedbackPairingStatus}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="5" Text="Demo mode" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="5" Grid.Column="1" Text="{Binding AboutDemoModeText}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="6" Text="Runtime" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="6" Grid.Column="1" Text="{Binding RuntimeCompatibilityText}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="7" Text="Backend" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="7" Grid.Column="1" Text="{Binding AboutBackendAvailabilityText}" TextColor="{StaticResource TextPrimary}" />
                            </Grid>

                            <VerticalStackLayout IsVisible="{Binding IsCrashReportPreviewVisible}" Spacing="8">
                                <Label Text="Preview" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Editor Text="{Binding CrashReportPreviewText}"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="220"
                                        MaximumHeightRequest="340"
                                        BackgroundColor="#071026"
                                        TextColor="{StaticResource TextPrimary}"
                                        FontFamily="Courier New"
                                        FontSize="13" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                        <Button Text="Preview" Command="{Binding PreviewCrashReportCommand}" WidthRequest="120" />
                        <Button Grid.Column="1" Text="⧉  Kopieer crashrapport" Command="{Binding CopyCrashReportCommand}" WidthRequest="210" />
                        <Button Grid.Column="2" Text="↗  Open GitHub issue" Command="{Binding OpenCrashReportIssueCommand}" WidthRequest="190" />
                        <Button Grid.Column="3" Text="Niet nu" Command="{Binding DismissCrashReportCommand}" WidthRequest="120" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsWakewordPromptVisible}" BackgroundColor="#AA000000">
            <Border Padding="26" WidthRequest="640" MaximumWidthRequest="640" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="18">
                        <Border BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" WidthRequest="64" HeightRequest="64">
                            <Label Text="🎙" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{StaticResource Accent}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Stemactivatie inschakelen?" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Start Ask DJ handsfree met “Hey DJ” terwijl DJConnect open is." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border IsVisible="{Binding HasWakewordNotice}" Padding="12" BackgroundColor="#2A2352" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding WakewordNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                    </Border>

                    <Border Padding="16" BackgroundColor="#160A2C" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Microfoon- en spraakherkenningstoestemming kunnen worden gevraagd." TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                            <Label Text="Stemactivatie werkt alleen terwijl de app open is. Push-to-talk blijft beschikbaar zonder wakeword; tekstchat blijft beschikbaar zonder microfoon." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                            <Label Text="Je kunt dit later uitschakelen in Instellingen." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="🎙  Stemactivatie inschakelen" HeightRequest="56" Command="{Binding EnableWakewordCommand}" />
                        <Button Grid.Column="1" Text="Niet nu" HeightRequest="56" Command="{Binding DismissWakewordPromptCommand}" />
                    </Grid>
                    <Button Text="♧  Meer over privacy" Command="{Binding ShowPrivacyFromWakewordCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsFeedbackOverlayVisible}" BackgroundColor="#AA000000">
            <Border Padding="24" WidthRequest="860" MaximumWidthRequest="860" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
                    <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="16">
                        <Border BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" WidthRequest="56" HeightRequest="56">
                            <Label Text="✎" FontSize="28" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{StaticResource Accent}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="Feedback delen" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Vertel wat beter kan of kopieer een privacy-safe bugreport." TextColor="{StaticResource TextSecondary}" />
                            <Label Text="DJConnect uploadt niets automatisch." TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="✕" Command="{Binding HideFeedbackCommand}" WidthRequest="52" />
                    </Grid>

                    <Border Grid.Row="1" IsVisible="{Binding HasFeedbackNotice}" Padding="12" BackgroundColor="#143A2A" Stroke="#35E56B" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding FeedbackNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                    </Border>

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Spacing="16">
                            <VerticalStackLayout Spacing="8" RadioButtonGroup.GroupName="FeedbackType" RadioButtonGroup.SelectedValue="{Binding SelectedFeedbackType, Mode=TwoWay}">
                                <Label Text="Type" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <HorizontalStackLayout Spacing="18">
                                    <RadioButton Content="Bug" Value="Bug" TextColor="{StaticResource TextPrimary}" />
                                    <RadioButton Content="Idee" Value="Idee" TextColor="{StaticResource TextPrimary}" />
                                    <RadioButton Content="Vraag" Value="Vraag" TextColor="{StaticResource TextPrimary}" />
                                    <RadioButton Content="App Store feedback" Value="App Store feedback" TextColor="{StaticResource TextPrimary}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,300" ColumnSpacing="18">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Bericht" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Editor Text="{Binding FeedbackText}"
                                            Placeholder="Wat gebeurde er? Wat verwachtte je?"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="150"
                                            MaximumHeightRequest="260"
                                            BackgroundColor="#586091"
                                            TextColor="{StaticResource TextPrimary}"
                                            PlaceholderColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="10">
                                    <Label Text="Context" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Border Padding="12" BackgroundColor="#160A2C" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                        <Label Text="{Binding FeedbackContextSummary}" FontFamily="Courier New" FontSize="13" TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" />
                                    </Border>
                                    <HorizontalStackLayout Spacing="10">
                                        <CheckBox IsChecked="{Binding IncludePrivacySafeLogs}" Color="{StaticResource Accent}" VerticalOptions="Center" />
                                        <Label Text="Privacy-safe logs toevoegen" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="Opt-in. Tokens, pairing codes en private waarden worden vóór preview, kopiëren en openen geredigeerd." TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout IsVisible="{Binding IsFeedbackPreviewVisible}" Spacing="8">
                                <Label Text="Preview" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                <Editor Text="{Binding FeedbackPreviewText}"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="220"
                                        MaximumHeightRequest="360"
                                        BackgroundColor="#071026"
                                        TextColor="{StaticResource TextPrimary}"
                                        FontFamily="Courier New"
                                        FontSize="13" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                        <Button Text="Preview" Command="{Binding PreviewFeedbackCommand}" WidthRequest="120" />
                        <Button Grid.Column="1" Text="⧉  Kopieer feedback" Command="{Binding CopyFeedbackCommand}" WidthRequest="190" />
                        <Button Grid.Column="2" Text="↗  Open GitHub issue" Command="{Binding OpenFeedbackIssueCommand}" WidthRequest="190" />
                        <Button Grid.Column="3" Text="Annuleren" Command="{Binding HideFeedbackCommand}" WidthRequest="120" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsWhatsNewVisible}" BackgroundColor="#CC050717">
            <Border Padding="28" WidthRequest="720" MaximumWidthRequest="720" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="18">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="18">
                        <Border BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" WidthRequest="64" HeightRequest="64">
                            <Label Text="✦" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{StaticResource Accent}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding WhatsNewTitle}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding WhatsNewSubtitle}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Grid>

                    <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoadingWhatsNew}" IsVisible="{Binding IsLoadingWhatsNew}" Color="{StaticResource Accent}" />

                    <ScrollView Grid.Row="2" HeightRequest="360">
                        <Label Text="{Binding WhatsNewBody}" TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" FontSize="16" />
                    </ScrollView>

                    <Label Grid.Row="3" Text="https://djconnect.dev" TextColor="{StaticResource TextSecondary}" />

                    <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Doorgaan" HeightRequest="56" Command="{Binding DismissWhatsNewCommand}" />
                        <Button Grid.Column="1" Text="↗  Bekijk online" HeightRequest="56" Clicked="OpenWhatsNewOnline" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsPermissionExplanationVisible}" BackgroundColor="#CC050717">
            <Border Padding="28" WidthRequest="620" BackgroundColor="#292875" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="18">
                        <Border BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" WidthRequest="64" HeightRequest="64">
                            <Label Text="{Binding PermissionIcon}" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{StaticResource Accent}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding PermissionTitle}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding PermissionIntro}" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border Padding="18" BackgroundColor="#3B367D" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding PermissionBodyPrimary}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                            <Label Text="{Binding PermissionBodySecondary}" TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" />
                            <Label IsVisible="{Binding HasPermissionBodyTertiary}" Text="{Binding PermissionBodyTertiary}" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding IsLocalNetworkPermission}" Padding="14" BackgroundColor="#160A2C" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding ClientAddress, StringFormat='Client adres: {0}'}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="{Binding PermissionContinueText}" HeightRequest="56" Clicked="ContinuePermissionExplanationClicked" />
                        <Button Grid.Column="1" Text="Niet nu" HeightRequest="56" Command="{Binding HidePermissionExplanationCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding IsLocalNetworkPermission}">
                        <Button Text="Kopieer Client adres" HeightRequest="52" IsEnabled="{Binding CanCopyClientAddress}" Clicked="CopyClientAddressClicked" />
                        <Button Grid.Column="1" Text="Open firewall instellingen" HeightRequest="52" Clicked="OpenPermissionSettingsClicked" />
                    </Grid>

                    <Button IsVisible="{Binding IsPermissionSettingsMode}" Text="{Binding PermissionSettingsText}" HeightRequest="52" Clicked="OpenPermissionSettingsClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
