                                    <Label Text="Geselecteerd" TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="1" Text="{Binding SelectedOutputText}" TextColor="{StaticResource TextPrimary}" />
                                    <Label Grid.Row="1" Text="Uitvoerapparaat" TextColor="{StaticResource TextSecondary}" />
