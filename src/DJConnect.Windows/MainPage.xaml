                                    <Button Grid.Row="1" Text="✦  Wat is er nieuw" Clicked="OpenWhatsNewLink" />
                                    <Button Grid.Row="1" Grid.Column="1" Text="▱  Feedback delen" Clicked="OpenFeedbackFromAbout" />
