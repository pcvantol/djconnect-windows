                        </Border>
                        <ActivityIndicator IsRunning="{Binding IsLoadingPlaylists}" IsVisible="{Binding IsLoadingPlaylists}" Color="{StaticResource Accent}" />
                        <Border IsVisible="{Binding HasNoPlaylistItems}" Padding="22" BackgroundColor="#202657" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Geen afspeellijsten" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Home Assistant gaf nog geen afspeellijsten terug." TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

