                                <Label Text="App versie" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding AppVersion}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="1" Text="Protocol" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding ProtocolVersion}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Text="Client type" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding ClientType}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="3" Text="Platform" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding PlatformName}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="4" Text="Website" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="4" Grid.Column="1" Text="{Binding WebsiteUrl}" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="5" Text="Taal" TextColor="{StaticResource TextSecondary}" />
                                <HorizontalStackLayout Grid.Row="5" Grid.Column="1" Spacing="8">
                                    <Label Text="EN" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                    <Switch IsToggled="{Binding IsDutch}" />
                                    <Label Text="NL" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                            <Label Text="Setup loopt via de Home Assistant DJConnect integration. Spotify playback vereist Spotify Premium." TextColor="{StaticResource TextPrimary}" LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <Button Text="↗  Start/setup" Clicked="OpenSetupLink" />
                                <Button Grid.Column="1" Text="♧  Privacy" Clicked="OpenPrivacyFromAbout" />
                                <Button Grid.Column="2" Text="▧  Juridisch" Clicked="OpenLegalFromAbout" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid x:Name="LogsPanel" IsVisible="False" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Logs" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Lokale diagnostiek. Kopiëren en preview gebruiken redaction; er wordt niets automatisch geüpload." TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="⧉  Logs kopiëren" Command="{Binding CopyLogsCommand}" />
                        <Button Grid.Column="2" Text="⌕" Command="{Binding ToggleLogSearchCommand}" Clicked="ToggleLogSearchClicked" WidthRequest="56" />
                        <Button Grid.Column="3" Text="⌫  Logs wissen" Command="{Binding ClearLogsCommand}" />
                    </Grid>

                    <Border Grid.Row="1" IsVisible="{Binding HasLogNotice}" Padding="12" BackgroundColor="#143A2A" Stroke="#35E56B" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding LogNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                    </Border>

                    <Grid Grid.Row="2" IsVisible="{Binding IsLogSearchVisible}" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
