                                    <Picker Grid.Row="1" Grid.Column="1" SelectedItem="{Binding AskDJMood}" TextColor="{StaticResource TextPrimary}" BackgroundColor="#2B3262">
                                        <Picker.Items>
                                            <x:String>Chill</x:String>
                                            <x:String>Groove</x:String>
                                            <x:String>Energy</x:String>
                                            <x:String>Party</x:String>
                                        </Picker.Items>
                                    </Picker>
                                    <Label Grid.Row="2" Text="Geschiedenis" TextColor="{StaticResource TextSecondary}" />
                                    <Button Grid.Row="2" Grid.Column="1" Text="⌫  Ask DJ geschiedenis wissen" Command="{Binding ClearHistoryCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                    <Label Text="Stemactivatie" TextColor="{StaticResource TextSecondary}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding WakewordEnabled}" IsEnabled="{Binding WakewordFeatureAvailable}" HorizontalOptions="Start" />
