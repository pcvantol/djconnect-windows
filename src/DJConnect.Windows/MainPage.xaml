<ContentPage x:Class="DJConnect.Windows.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding T[Xaml_DJConnect]}"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid ColumnDefinitions="290,*">
            <Border Grid.Column="0"
                    Margin="0,42,0,0"
                    BackgroundColor="#101126"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 0,8,8,0">
                <VerticalStackLayout Padding="20,24" Spacing="10">
                    <Button x:Name="NowPlayingNavButton" Text="{Binding T[Xaml_Speelt_Nu]}" Clicked="ShowNowPlaying" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="AskDJNavButton" Text="{Binding T[Xaml_Ask_DJ]}" Clicked="ShowAskDJ" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="QueueNavButton" Text="{Binding T[Xaml_Wachtrij]}" Clicked="ShowQueue" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="PlaylistsNavButton" Text="{Binding T[Xaml_Afspeellijsten]}" Clicked="ShowPlaylists" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="GamesNavButton" Text="{Binding T[Xaml_Games]}" Clicked="ShowGames" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="SettingsNavButton" Text="{Binding T[Xaml_Instellingen]}" Clicked="ShowSettings" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="LogsNavButton" Text="{Binding T[Xaml_Logs]}" Clicked="ShowLogs" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="AboutNavButton" Text="{Binding T[Xaml_Over]}" Clicked="ShowAbout" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="LegalNavButton" Text="{Binding T[Xaml_Juridisch]}" Clicked="ShowLegal" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="PrivacyNavButton" Text="{Binding T[Xaml_Privacy]}" Clicked="ShowPrivacy" HorizontalOptions="Fill" Padding="20,9" />
                    <Button x:Name="FeedbackNavButton" Text="{Binding T[Xaml_Feedback_delen]}" Command="{Binding ShowFeedbackCommand}" HorizontalOptions="Fill" Padding="20,9" />
                </VerticalStackLayout>
            </Border>

            <Grid Grid.Column="1" Padding="38,40,34,28">
                <ScrollView x:Name="NowPlayingPanel">
                    <VerticalStackLayout Spacing="24" MaximumWidthRequest="1180">
                        <Border Padding="28"
                                Background="{StaticResource CardBrush}"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="20">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
                                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                        <Border WidthRequest="28"
                                                HeightRequest="28"
                                                Stroke="{Binding NowPlayingPairingStatusColor}"
                                                StrokeThickness="2"
                                                StrokeShape="RoundRectangle 14"
                                                BackgroundColor="Transparent"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding NowPlayingPairingStatusIcon}"
                                                   TextColor="{Binding NowPlayingPairingStatusColor}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding NowPlayingPairingStatusText}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding T[Xaml_Home_Assistant]}" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                        <Label Text="{Binding NowPlayingMusicBackendStatusText}" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                        <Border WidthRequest="12"
                                                HeightRequest="12"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                BackgroundColor="{Binding NowPlayingMusicBackendStatusColor}"
                                                VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Button Grid.Column="2" Text="↻" Command="{Binding RefreshCommand}" WidthRequest="56" />
                                </Grid>

                                <Border Grid.Row="1" IsVisible="{Binding HasNotice}" Padding="14" BackgroundColor="#2A2352" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                    <Label Text="{Binding Notice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                </Border>

                                <Grid Grid.Row="2" WidthRequest="520" HeightRequest="520" HorizontalOptions="Center" BackgroundColor="#090613">
                                    <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill" IsVisible="{Binding HasArtwork}" />
                                    <VerticalStackLayout IsVisible="{Binding HasNoArtwork}" HorizontalOptions="Center" VerticalOptions="Center" Spacing="14">
                                        <Image Source="djconnect_icon.png" WidthRequest="180" HeightRequest="180" />
                                        <Label Text="♪" FontSize="62" TextColor="{StaticResource Accent}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Grid>

                                <VerticalStackLayout Grid.Row="3" Spacing="8">
                                    <Label Text="{Binding TrackTitle}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding TrackArtist}" FontSize="21" TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding TrackAlbum}" FontSize="16" TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Grid Grid.Row="4" RowDefinitions="Auto,Auto" RowSpacing="4">
                                    <Slider x:Name="PlaybackPositionSlider"
                                            Minimum="0"
                                            Maximum="{Binding PlaybackDurationMs}"
                                            Value="{Binding PlaybackPositionMs, Mode=TwoWay}"
                                            IsEnabled="{Binding CanUsePlaybackFeatures}"
                                            DragCompleted="PlaybackSeekCompleted" />
                                    <Label Grid.Row="1" Text="{Binding PlaybackTimeLabel}" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                </Grid>

                                <HorizontalStackLayout Grid.Row="5" HorizontalOptions="Center" Spacing="22">
                                    <Button Text="↶ 15" Command="{Binding SeekBackwardCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="108" HeightRequest="62" />
                                    <Button Text="15 ↷" Command="{Binding SeekForwardCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="108" HeightRequest="62" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="6" HorizontalOptions="Center" Spacing="28">
                                    <Button Text="◀" Command="{Binding PreviousCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="108" HeightRequest="66" />
                                    <Button Text="{Binding PlayPauseGlyph}" Command="{Binding PlayCommand}" IsEnabled="{Binding CanStartPlayback}" WidthRequest="138" HeightRequest="74" FontSize="24" />
                                    <Button Text="▶" Command="{Binding NextCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="108" HeightRequest="66" />
                                    <Button Text="♡" Command="{Binding SaveCurrentTrackCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="88" HeightRequest="66" />
                                    <Button Text="{Binding T[Xaml_Track_Insight]}" Command="{Binding OpenTrackInsightCommand}" IsEnabled="{Binding CanUsePlaybackFeatures}" WidthRequest="156" HeightRequest="66" />
                                </HorizontalStackLayout>

                                <VerticalStackLayout Grid.Row="7" Spacing="10">
                                    <Border IsVisible="{Binding HasTrackInsightNotice}" Padding="12" BackgroundColor="#2A2352" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                        <Label Text="{Binding TrackInsightNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                    </Border>
                                    <Border IsVisible="{Binding HasTrackInsightPanel}" Padding="12" BackgroundColor="#151936" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                        <VerticalStackLayout Spacing="8" BindingContext="{Binding TrackInsightPanel}">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Text="{Binding Header}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                                <Label Grid.Column="1" Text="{Binding MetaLabel}" TextColor="{StaticResource TextSecondary}" FontSize="11" HorizontalTextAlignment="End" />
                                            </Grid>
                                            <CollectionView ItemsSource="{Binding Context}" IsVisible="{Binding HasContext}">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="0,3" ColumnDefinitions="150,*" ColumnSpacing="10">
                                                            <VerticalStackLayout Spacing="1">
                                                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            </VerticalStackLayout>
                                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                <Label Text="{Binding Detail}" IsVisible="{Binding HasDetail}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                                            </VerticalStackLayout>
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                            <CollectionView ItemsSource="{Binding Sections}" IsVisible="{Binding HasSections}">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="0,3" ColumnDefinitions="150,*" ColumnSpacing="10">
                                                            <VerticalStackLayout Spacing="1">
                                                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            </VerticalStackLayout>
                                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                <Label Text="{Binding Detail}" IsVisible="{Binding HasDetail}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                                            </VerticalStackLayout>
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </Border>
                                </VerticalStackLayout>

                                <Grid Grid.Row="8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Label Text="🔈" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    <Slider Grid.Column="1" Value="{Binding VolumePercent, Mode=TwoWay}" Minimum="0" Maximum="100" IsEnabled="{Binding CanUsePlaybackFeatures}" />
                                    <Label Grid.Column="2" Text="{Binding VolumeLabel}" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Grid ColumnDefinitions="Auto,320" ColumnSpacing="14">
                            <Label Text="{Binding T[Xaml_Uitvoerapparaat]}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            <Picker Grid.Column="1"
                                    Title="{Binding T[Xaml_Geen_uitvoerapparaat_geselecteerd]}"
                                    ItemsSource="{Binding OutputDevices}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedOutput, Mode=TwoWay}"
                                    IsEnabled="{Binding CanUsePlaybackFeatures}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="{StaticResource Surface}" />
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid x:Name="AskDJPanel" IsVisible="False" RowDefinitions="Auto,*,Auto" RowSpacing="18">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding T[Xaml_Ask_DJ_3]}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding ConnectionStatusText}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="⌕" WidthRequest="52" />
                        <Button Grid.Column="2" Text="↻" Command="{Binding RefreshCommand}" WidthRequest="52" />
                        <Button Grid.Column="3" Text="⌫" Command="{Binding ClearHistoryCommand}" WidthRequest="52" />
                    </Grid>

                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="16">
                            <Border IsVisible="{Binding HasAskDJNotice}" Padding="14" BackgroundColor="#2A2352" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                <Label Text="{Binding AskDJNotice}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                            </Border>
                            <Border Padding="18" BackgroundColor="#242A5B" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Label Text="ϟ" FontSize="20" TextColor="{StaticResource Accent}" />
                                        <Label Grid.Column="1" Text="{Binding T[Xaml_Mood]}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <Label Grid.Column="2" Text="{Binding T[Xaml_Energy_×]}" TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                    </Grid>
                                    <Slider Value="0.70" />
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Label Text="{Binding T[Xaml_Chill]}" TextColor="{StaticResource TextSecondary}" />
                                        <Label Grid.Column="1" Text="{Binding T[Xaml_Groove]}" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                                        <Label Grid.Column="2" Text="{Binding T[Xaml_Energy]}" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                                        <Label Grid.Column="3" Text="{Binding T[Xaml_Party]}" HorizontalTextAlignment="End" TextColor="{StaticResource TextSecondary}" />
                                    </Grid>
                                    <Label Text="{Binding T[Xaml_Mood_stuurt_Ask_DJ_s_aanbevelingen_van_rusti]}" TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Border>

                            <CollectionView ItemsSource="{Binding Messages}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4">
                                            <Border Padding="14" Margin="0,2" WidthRequest="720" HorizontalOptions="{Binding BubbleAlignment}" BackgroundColor="{Binding BubbleBackground}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                <VerticalStackLayout Spacing="8">
                                                    <Label Text="{Binding RoleLabel}" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                                    <Label LineBreakMode="WordWrap" TextColor="{StaticResource TextPrimary}">
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="{Binding GeneratedTextSpark}" TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                                                <Span Text="{Binding DisplayText}" />
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                    <Border IsVisible="{Binding HasTrackInsight}" Padding="12" BackgroundColor="#151936" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                        <VerticalStackLayout Spacing="10" BindingContext="{Binding TrackInsight}">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                <Label Text="{Binding Header}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                                                <Label Grid.Column="1" Text="{Binding MetaLabel}" TextColor="{StaticResource TextSecondary}" FontSize="11" HorizontalTextAlignment="End" />
                                                            </Grid>
                                                            <CollectionView ItemsSource="{Binding Sections}" IsVisible="{Binding HasSections}">
                                                                <CollectionView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Padding="0,3" ColumnDefinitions="150,*" ColumnSpacing="10">
                                                                            <VerticalStackLayout Spacing="1">
                                                                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                                            </VerticalStackLayout>
                                                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                                <Label Text="{Binding Detail}" IsVisible="{Binding HasDetail}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                                                            </VerticalStackLayout>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </CollectionView.ItemTemplate>
                                                            </CollectionView>
                                                            <VerticalStackLayout Spacing="4" IsVisible="{Binding HasContext}">
                                                                <Label Text="{Binding T[Xaml_Context]}" TextColor="{StaticResource TextSecondary}" FontSize="11" FontAttributes="Bold" />
                                                                <CollectionView ItemsSource="{Binding Context}">
                                                                    <CollectionView.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Padding="0,3" ColumnDefinitions="150,*" ColumnSpacing="10">
                                                                                <VerticalStackLayout Spacing="1">
                                                                                    <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                    <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                                                </VerticalStackLayout>
                                                                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                                    <Label Text="{Binding Detail}" IsVisible="{Binding HasDetail}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                    <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                                                                </VerticalStackLayout>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </CollectionView.ItemTemplate>
                                                                </CollectionView>
                                                            </VerticalStackLayout>
                                                            <CollectionView ItemsSource="{Binding Timeline}" IsVisible="{Binding HasTimeline}">
                                                                <CollectionView.ItemsLayout>
                                                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                                                                </CollectionView.ItemsLayout>
                                                                <CollectionView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Padding="8,6" BackgroundColor="#242A5B" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                                            <VerticalStackLayout Spacing="1" WidthRequest="120">
                                                                                <Label Text="{Binding Title}" TextColor="{StaticResource TextPrimary}" FontSize="12" LineBreakMode="TailTruncation" />
                                                                                <Label Text="{Binding Subtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="10" LineBreakMode="TailTruncation" />
                                                                            </VerticalStackLayout>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </CollectionView.ItemTemplate>
                                                            </CollectionView>
                                                            <CollectionView ItemsSource="{Binding Tips}" IsVisible="{Binding HasTips}">
                                                                <CollectionView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Padding="0,2" ColumnDefinitions="18,*">
                                                                            <Label Text="•" TextColor="{StaticResource Accent}" />
                                                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                                <Label Text="{Binding Title}" TextColor="{StaticResource TextPrimary}" FontSize="13" />
                                                                                <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                                                            </VerticalStackLayout>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </CollectionView.ItemTemplate>
                                                            </CollectionView>
                                                            <CollectionView ItemsSource="{Binding Limitations}" IsVisible="{Binding HasLimitations}">
                                                                <CollectionView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Padding="0,2" ColumnDefinitions="18,*">
                                                                            <Label Text="!" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" />
                                                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                                <Label Text="{Binding Title}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                                                                <Label Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}" TextColor="{StaticResource TextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                                                                                <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                                                            </VerticalStackLayout>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </CollectionView.ItemTemplate>
                                                            </CollectionView>
                                                            <VerticalStackLayout Spacing="4" IsVisible="{Binding HasProviderDiagnostics}">
                                                                <Label Text="{Binding T[Xaml_Sources_diagnostics]}" TextColor="{StaticResource TextSecondary}" FontSize="11" FontAttributes="Bold" />
                                                                <CollectionView ItemsSource="{Binding ProviderDiagnostics}">
                                                                    <CollectionView.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Padding="0,2" ColumnDefinitions="150,*" ColumnSpacing="10">
                                                                                <Label Text="{Binding Title}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                                    <Label Text="{Binding Subtitle}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                                                                    <Label Text="{Binding Meta}" IsVisible="{Binding HasMeta}" TextColor="{StaticResource TextSecondary}" FontSize="10" LineBreakMode="WordWrap" />
                                                                                </VerticalStackLayout>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </CollectionView.ItemTemplate>
                                                                </CollectionView>
                                                            </VerticalStackLayout>
                                                        </VerticalStackLayout>
                                                    </Border>
                                                    <Label Text="{Binding DeliveryLabel}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                                    <Button Text="{Binding T[Xaml_Audio_opnieuw_afspelen]}" IsVisible="{Binding HasAudio}" Clicked="ReplayAudioClicked" HorizontalOptions="Start" />
                                                    <CollectionView ItemsSource="{Binding Images}" IsVisible="{Binding HasImages}">
                                                        <CollectionView.ItemsLayout>
                                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                                        </CollectionView.ItemsLayout>
                                                        <CollectionView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="8" BackgroundColor="#151936" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                                    <VerticalStackLayout Spacing="6" WidthRequest="150">
                                                                        <Image Source="{Binding DisplayUrl}" WidthRequest="134" HeightRequest="96" Aspect="AspectFill" />
                                                                        <Label Text="{Binding DisplayLabel}" TextColor="{StaticResource TextSecondary}" FontSize="12" LineBreakMode="TailTruncation" />
                                                                    </VerticalStackLayout>
                                                                </Border>
                                                            </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                    </CollectionView>
                                                    <CollectionView ItemsSource="{Binding DisplaySources}" IsVisible="{Binding HasSources}">
                                                        <CollectionView.ItemsLayout>
                                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                                        </CollectionView.ItemsLayout>
                                                        <CollectionView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="8,4" BackgroundColor="#151936" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                                    <Label Text="{Binding DisplayLabel}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                    </CollectionView>
                                                    <CollectionView ItemsSource="{Binding PlaybackActions}" IsVisible="{Binding HasPlaybackActions}" HeightRequest="48" VerticalOptions="Start">
                                                        <CollectionView.ItemsLayout>
                                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                                        </CollectionView.ItemsLayout>
                                                        <CollectionView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Text="{Binding DisplayLabel}" Clicked="AskDJActionClicked" HeightRequest="42" VerticalOptions="Start" />
                                                            </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                    </CollectionView>
                                                    <CollectionView ItemsSource="{Binding ConfirmationActions}" IsVisible="{Binding HasPlaybackActions}" HeightRequest="48" VerticalOptions="Start">
                                                        <CollectionView.ItemsLayout>
                                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                                        </CollectionView.ItemsLayout>
                                                        <CollectionView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Text="{Binding DisplayLabel}" Clicked="AskDJActionClicked" HeightRequest="42" VerticalOptions="Start" />
                                                            </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                    </CollectionView>
                                                    <CollectionView ItemsSource="{Binding Items}" IsVisible="{Binding HasItems}">
                                                        <CollectionView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="10" Margin="0,3" BackgroundColor="#151936" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8">
                                                                    <Grid ColumnDefinitions="56,*" ColumnSpacing="10">
                                                                        <Image Source="{Binding ImageUrl}" WidthRequest="56" HeightRequest="56" Aspect="AspectFill" />
                                                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                                            <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                                                            <Label Text="{Binding Subtitle}" TextColor="{StaticResource TextSecondary}" />
                                                                            <Label Text="{Binding PlayedAtLabel}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                                                        </VerticalStackLayout>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                    </CollectionView>
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label IsVisible="{Binding HasVoiceStatus}" Text="{Binding VoiceStatus}" TextColor="{StaticResource TextSecondary}" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,64,64" ColumnSpacing="10">
                            <Editor Text="{Binding AskDJText}" Placeholder="{Binding AskDJPlaceholder}" MinimumHeightRequest="58" BackgroundColor="#586091" TextColor="{StaticResource TextPrimary}" />
                            <Button Grid.Column="1" Text="🎙" Command="{Binding TogglePushToTalkCommand}" IsEnabled="{Binding CanUseAskDJ}" />
                            <Button Grid.Column="2" Text="➤" Command="{Binding SendAskDJCommand}" IsEnabled="{Binding CanSendAskDJ}" />
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="QueuePanel" IsVisible="False" RowDefinitions="Auto,Auto,*" RowSpacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding QueueTitle}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding ConnectionStatusText}" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
