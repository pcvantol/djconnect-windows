                               Placeholder="Zoek in logs"
                               Text="{Binding LogSearchText}"
                               BackgroundColor="#071026"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextSecondary}"
                               Completed="LogSearchEntryCompleted" />
